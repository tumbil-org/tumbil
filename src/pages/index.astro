---
import "../styles/global.css";
import LaundryLoadingIcon from '../components/LaundryLoadingIcon.astro';

// Access the environment variable in the frontmatter
const apiUrl = import.meta.env.VITE_API_URL;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Tumbil</title>
  
  <!-- Favicon -->
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
  <link rel="icon" type="image/png" sizes="24x24" href="/favicon-24x24.png">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="64x64" href="/favicon-64x64.png">
  <link rel="apple-touch-icon" sizes="120x120" href="/favicon-120x120.png">
  
  <style>
    html {
      overflow: hidden; /* Added this line to prevent scrolling */
    }
    body {
      background-image: url('/splash_background.jpg');
      background-size: cover;
      background-repeat: no-repeat;
      background-position: top;
      margin: 0;
      padding: 0;
      color: white;
      text-align: center;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      position: relative;
      overflow: hidden; /* Added this line to prevent scrolling */
    }
    .hidden {
      opacity: 0 !important;
      transform: scale(0.95) !important;
      pointer-events: none;
    }
    .form-input {
      width: 80%;
      background-color: transparent;
      border: 2px solid white;
      color: white;
      padding: 10px;
      margin-bottom: 48px;
      border-radius: 12px;
    }
    .form-input::placeholder {
      color: rgba(255, 255, 255, 0.7);
    }
    .submit-button {
      width: 80%;
      background-color: #0079AC;
      color: white;
      border: none;
      padding: 10px;
      border-radius: 12px;
      cursor: pointer;
      display: flex;
      justify-content: center;
      align-items: center;
      height: 48px; /* Set a fixed height */
      margin: 0 auto; /* Center the button */
    }
    .submit-button span {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 100%;
      height: 100%;
    }
    #loadingIcon {
      width: 24px;
      height: 24px;
    }
    #step1, #step2, #confirmationScreen {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      transition: opacity 0.5s ease, transform 0.5s ease;
      opacity: 1;
      transform: scale(1);
    }
    #step2 .form-container, #confirmationScreen .content {
      width: 90%;
      max-width: 500px;
    }
    #overlay {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: rgba(0, 0, 0, 0.45);
      backdrop-filter: blur(10px);
      z-index: -1;
      transition: opacity 0.5s ease;
      opacity: 0;
    }
    #overlay.active {
      opacity: 1;
    }
    #loadingOverlay {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: rgba(0, 0, 0, 0.75);
      display: flex;
      justify-content: center;
      align-items: center;
      z-index: 100;
      opacity: 0;
      transition: opacity 0.5s ease;
    }
    #loadingOverlay.active {
      opacity: 1;
    }
  </style>
</head>
<body>
  <div id="overlay"></div>
  <div id="loadingOverlay" class="hidden">
    <LaundryLoadingIcon />
  </div>

  <div id="step1">
    <header class="absolute top-2 left-2 lg:top-6 lg:left-6 p-4">
      <a href="https://tumbil.com">
        <img src="/logo.svg" alt="Tumbil Logo" class="logo" />
      </a>
    </header>
    <nav class="absolute top-4 right-4 lg:top-8 lg:right-8 p-2 z-10">
      <a
        href="/tumbil-academy"
        class="text-white text-sm lg:text-base px-4 py-2 rounded-full border border-white/40 hover:bg-white/10 transition-colors"
      >
        Tumbil Academy
      </a>
    </nav>
    
    <main class="flex items-center justify-center flex-grow">
      <div class="text-center mx-4">
        <h1 class="mb-4 text-6xl lg:text-7xl xl:text-8xl">Laundry Reimagined</h1>
        <p class="w-5/6 md:w-3/4 mx-auto text-lg xl:text-2xl">Sign up to become a laundry professional and earn up to $4,000/month working from home</p>
        <form id="emailForm" class="flex flex-col sm:flex-row max-w-lg mx-5 sm:mx-auto space-y-3 sm:space-y-0 sm:space-x-3 mt-7 px-4 sm:px-0">
          <input 
            type="email" 
            id="emailInput"
            name="email"
            placeholder="Email" 
            required
            class="flex-grow text-gray-900 px-4 h-12 py-2 border border-gray-300 rounded-2xl focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" 
          />
          <button 
            type="submit" 
            class="px-9 h-12 pt-1 bg-blue-600 shadow-black/25 shadow-md 
            hover:shadow-black/40 hover:shadow-lg
            text-white rounded-2xl active:bg-blue-400
            transition-all duration-300"
          >
            Let's go
          </button>
        </form>
      </div>
    </main>
  </div>

  <div id="step2" class="hidden">
    <div class="form-container">
      <h2 class="text-3xl mb-8">amazing, just a few questions</h2>
      <form id="fullForm">
        <input type="hidden" id="hiddenEmail" name="email" />
        <input 
          type="text" 
          id="firstNameInput"
          name="firstName"
          placeholder="first name" 
          required
          class="form-input"
        />
        <input 
          type="text" 
          id="lastNameInput"
          name="lastName"
          placeholder="last name" 
          required
          class="form-input"
        />
        <input 
          type="tel" 
          id="phoneInput"
          name="phone"
          placeholder="phone number" 
          required
          class="form-input"
        />
        <input 
          type="text" 
          id="postalCodeInput"
          name="postalCode"
          placeholder="postal code" 
          required
          class="form-input"
        />
        <button 
          type="submit" 
          class="submit-button"
        >
          <span id="submitText">Submit</span>
          <span id="loadingIcon" class="hidden">
            <LaundryLoadingIcon />
          </span>
        </button>
      </form>
    </div>
  </div>

  <div id="confirmationScreen" class="hidden">
    <div class="content">
      <a href="https://tumbil.com">
        <img src="/logo.svg" alt="Tumbil Logo" class="mx-auto mb-4" style="width: 200px;" />
      </a>
      <h2 class="text-3xl mb-4">perfect, we got your info and our team will be in touch soon</h2>
    </div>
  </div>

  <div id="message" class="mt-4 text-lg absolute bottom-4 left-0 right-0"></div>

  <script define:vars={{ apiUrl }}>
    const step1 = document.getElementById('step1');
    const step2 = document.getElementById('step2');
    const confirmationScreen = document.getElementById('confirmationScreen');
    const emailForm = document.getElementById('emailForm');
    const emailInput = document.getElementById('emailInput');
    const hiddenEmail = document.getElementById('hiddenEmail');
    const fullForm = document.getElementById('fullForm');
    const messageElement = document.getElementById('message');
    const overlay = document.getElementById('overlay');
    const loadingOverlay = document.getElementById('loadingOverlay');
    const submitText = document.getElementById('submitText');
    const loadingIcon = document.getElementById('loadingIcon');

    function transition(hideElement, showElement) {
      hideElement.classList.add('hidden');
      setTimeout(() => {
        showElement.classList.remove('hidden');
      }, 300);
    }

    emailForm?.addEventListener('submit', function(e) {
      e.preventDefault();
      if (emailInput instanceof HTMLInputElement && emailInput.checkValidity()) {
        if (hiddenEmail instanceof HTMLInputElement) {
          hiddenEmail.value = emailInput.value;
        }
        transition(step1, step2);
        overlay?.classList.add('active');
      } else if (emailInput instanceof HTMLInputElement) {
        emailInput.reportValidity();
      }
    });

    fullForm?.addEventListener('submit', async function(e) {
      e.preventDefault();
      const formData = new FormData(fullForm);
      const formProps = Object.fromEntries(formData);

      if (!messageElement) return;

      // Show loading icon and hide form fields
      loadingOverlay?.classList.remove('hidden');
      loadingOverlay?.classList.add('active');

      try {
        const response = await fetch(`${apiUrl}/add-contact`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify(formProps),
        });

        const result = await response.json();
        
        if (response.ok) {
          transition(step2, confirmationScreen);
        } else {
          handleFormError(result);
        }
      } catch (error) {
        console.error('Error:', error);
        messageElement.textContent = 'There was an error submitting your form. Please try again.';
        messageElement.style.color = 'red';
      } finally {
        // Hide loading icon and show form fields
        loadingOverlay?.classList.add('hidden');
        loadingOverlay?.classList.remove('active');
      }
    });

    function handleFormError(result) {
      let userFriendlyMessage;

      if (result.error && result.error.code === 'uniqueness_conflict') {
        userFriendlyMessage = 'Sorry, looks like someone has already registered with this email.';
      } else {
        userFriendlyMessage = 'There was an issue with your submission. Please try again.';
      }

      messageElement.textContent = userFriendlyMessage;
      messageElement.style.color = 'red';
    }
  </script>
</body>
</html>
